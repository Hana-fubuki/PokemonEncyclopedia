        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: capitalize;
        color: #1f2937;
        background: #e5e7eb;
    }

    .type-fire { background: #fed7aa; }
    .type-water { background: #bfdbfe; }
    .type-grass { background: #bbf7d0; }
    .type-electric { background: #fef08a; }
    .type-ice { background: #cffafe; }
    .type-fighting { background: #fecaca; }
    .type-poison { background: #e9d5ff; }
    .type-ground { background: #f5d0a9; }
    .type-flying { background: #ddd6fe; }
    .type-psychic { background: #fbcfe8; }
    .type-bug { background: #d9f99d; }
    .type-rock { background: #e7e5e4; }
    .type-ghost { background: #ddd6fe; }
    .type-dragon { background: #c7d2fe; }
