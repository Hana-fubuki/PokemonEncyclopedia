@page "/"
@rendermode InteractiveServer
@implements IDisposable
@inject PokemonApiClient PokemonApi
@inject PokemonFilterState FilterState

<PageTitle>Pokédex</PageTitle>

<div class="pokedex-container">
    <aside class="filters-sidebar">
        <div class="filters-header">
            <h2>Filters</h2>
            <button class="clear-button" @onclick="FilterState.ClearFilters">Clear</button>
        </div>

        <label class="search-label">
            <span>Search</span>
            <input class="search-input"
                   value="@FilterState.SearchText"
                   @oninput="HandleSearchInput"
                   placeholder="Search Pokémon..." />
        </label>

        <div class="filter-group">
            <div class="filter-title">Generation</div>
            @foreach (var generation in Enumerable.Range(1, 9))
            {
                <label class="filter-check">
                    <input type="checkbox"
                           checked="@FilterState.SelectedGenerations.Contains(generation)"
                           @onchange="() => FilterState.ToggleGeneration(generation)" />
                    <span>Gen @generation</span>
                </label>
            }
        </div>

        <div class="filter-group">
            <div class="filter-title">Type</div>
            @foreach (var type in KnownTypes)
            {
                <label class="filter-check">
                    <input type="checkbox"
                           checked="@FilterState.SelectedTypes.Contains(type)"
                           @onchange="() => FilterState.ToggleType(type)" />
                    <span class="type-pill type-@type">@type</span>
                </label>
            }
        </div>

        <div class="filter-group">
            <div class="filter-title">Rarity</div>
            <label class="filter-check">
                <input type="checkbox"
                       checked="@FilterState.IncludeLegendary"
                       @onchange="(ChangeEventArgs e) => FilterState.IncludeLegendary = (bool?)e.Value ?? true" />
                <span>Include Legendary</span>
            </label>
            <label class="filter-check">
                <input type="checkbox"
                       checked="@FilterState.IncludeMythical"
                       @onchange="(ChangeEventArgs e) => FilterState.IncludeMythical = (bool?)e.Value ?? true" />
                <span>Include Mythical</span>
            </label>
        </div>
    </aside>

    <section class="pokedex-content">
        <div class="pokedex-header">
            <div>
                <h1>Pokédex</h1>
                <p>Select a Pokémon to view details.</p>
            </div>
            <div class="result-count">@_filteredPokemon.Count Pokémon</div>
        </div>

        @if (_pokemon is null)
        {
            <p><em>Loading...</em></p>
        }
        else if (_filteredPokemon.Count == 0)
        {
            <p class="muted">No Pokémon match the selected filters.</p>
        }
        else
        {
            <div class="pokemon-grid">
                @foreach (var pokemon in _filteredPokemon)
                {
                    var sprite = pokemon.Sprites?.Other?.DreamWorld?.FrontDefault
                        ?? pokemon.Sprites?.Other?.OfficialArtwork?.FrontDefault
                        ?? pokemon.Sprites?.FrontDefault;

                    <a class="pokemon-card" href="@($"/pokemon/{pokemon.Name}")">
                        <div class="pokemon-image">
                            @if (!string.IsNullOrWhiteSpace(sprite))
                            {
                                <img src="@sprite" alt="@pokemon.Name sprite" loading="lazy" />
                            }
                            else
                            {
                                <div class="pokemon-placeholder">No sprite</div>
                            }
                        </div>
                        <div class="pokemon-meta">
                            <div class="pokemon-name">#@pokemon.Id @pokemon.Name</div>
                            <div class="pokemon-types">
                                @if (pokemon.Types is not null)
                                {
                                    @foreach (var type in pokemon.Types.Select(t => t.Type.Name))
                                    {
                                        <span class="type-pill type-@type">@type</span>
                                    }
                                }
                            </div>
                        </div>
                    </a>
                }
            </div>
        }
    </section>
</div>

@code {
    private IReadOnlyList<PokeApiNet.Pokemon>? _pokemon;
    private IReadOnlyList<PokeApiNet.Pokemon> _filteredPokemon = Array.Empty<PokeApiNet.Pokemon>();
    private IReadOnlySet<string>? _legendaryPokemonNames;

    protected override async Task OnInitializedAsync()
    {
        FilterState.Changed += HandleFilterChanged;
        var pokemonTask = PokemonApi.GetAllPokemonAsync();
        var legendaryTask = PokemonApi.GetLegendaryPokemonNamesAsync();
        
        await Task.WhenAll(pokemonTask, legendaryTask).ConfigureAwait(false);
        
        _pokemon = await pokemonTask.ConfigureAwait(false);
        _legendaryPokemonNames = await legendaryTask.ConfigureAwait(false);
        ApplyFilters();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        FilterState.Changed -= HandleFilterChanged;
    }

    private void HandleFilterChanged()
    {
        ApplyFilters();
        _ = InvokeAsync(StateHasChanged);
    }

    private void HandleSearchInput(ChangeEventArgs args)
    {
        FilterState.SearchText = args.Value?.ToString() ?? string.Empty;
    }

    private void ApplyFilters()
    {
        if (_pokemon is null)
        {
            _filteredPokemon = Array.Empty<PokeApiNet.Pokemon>();
            return;
        }

        var search = FilterState.SearchText.Trim();
        _filteredPokemon = _pokemon
            .Where(pokemon => MatchesSearch(pokemon, search))
            .Where(MatchesGeneration)
            .Where(MatchesType)
            .Where(MatchesLegendary)
            .Where(MatchesMythical)
            .OrderBy(pokemon => pokemon.Id)
            .ToArray();
    }

    private bool MatchesSearch(PokeApiNet.Pokemon pokemon, string search)
    {
        return string.IsNullOrWhiteSpace(search) ||
               pokemon.Name.Contains(search, StringComparison.OrdinalIgnoreCase) ||
               pokemon.Id.ToString().Contains(search, StringComparison.OrdinalIgnoreCase);
    }

    private bool MatchesGeneration(PokeApiNet.Pokemon pokemon)
    {
        return FilterState.SelectedGenerations.Contains(GetGeneration(pokemon.Id));
    }

    private bool MatchesType(PokeApiNet.Pokemon pokemon)
    {
        if (FilterState.SelectedTypes.Count == 0)
            return true;

        return pokemon.Types.Any(type => FilterState.SelectedTypes.Contains(type.Type.Name));
    }

    private bool MatchesLegendary(PokeApiNet.Pokemon pokemon)
    {
        if (_legendaryPokemonNames is null)
            return true;

        var isLegendary = _legendaryPokemonNames.Contains(pokemon.Name);
        return FilterState.IncludeLegendary || !isLegendary;
    }

    private bool MatchesMythical(PokeApiNet.Pokemon pokemon)
    {
        // For now, we check if it's NOT legendary and has mythical characteristics
        // This is a simple heuristic - in future could fetch actual species data
        var isMythicalName = pokemon.Name.Contains("mew", StringComparison.OrdinalIgnoreCase) ||
                             pokemon.Name.Contains("celebi", StringComparison.OrdinalIgnoreCase) ||
                             pokemon.Name.Contains("jirachi", StringComparison.OrdinalIgnoreCase) ||
                             pokemon.Name.Contains("deoxys", StringComparison.OrdinalIgnoreCase) ||
                             pokemon.Name.Contains("phione", StringComparison.OrdinalIgnoreCase) ||
                             pokemon.Name.Contains("manaphy", StringComparison.OrdinalIgnoreCase) ||
                             pokemon.Name.Contains("darkrai", StringComparison.OrdinalIgnoreCase) ||
                             pokemon.Name.Contains("shaymin", StringComparison.OrdinalIgnoreCase) ||
                             pokemon.Name.Contains("arceus", StringComparison.OrdinalIgnoreCase) ||
                             pokemon.Name.Contains("victini", StringComparison.OrdinalIgnoreCase) ||
                             pokemon.Name.Contains("keldeo", StringComparison.OrdinalIgnoreCase) ||
                             pokemon.Name.Contains("meloetta", StringComparison.OrdinalIgnoreCase) ||
                             pokemon.Name.Contains("genesect", StringComparison.OrdinalIgnoreCase) ||
                             pokemon.Name.Contains("diancie", StringComparison.OrdinalIgnoreCase) ||
                             pokemon.Name.Contains("hoopa", StringComparison.OrdinalIgnoreCase) ||
                             pokemon.Name.Contains("volcanion", StringComparison.OrdinalIgnoreCase) ||
                             pokemon.Name.Contains("magearna", StringComparison.OrdinalIgnoreCase) ||
                             pokemon.Name.Contains("marshadow", StringComparison.OrdinalIgnoreCase) ||
                             pokemon.Name.Contains("zeraora", StringComparison.OrdinalIgnoreCase) ||
                             pokemon.Name.Contains("meltan", StringComparison.OrdinalIgnoreCase) ||
                             pokemon.Name.Contains("melmetal", StringComparison.OrdinalIgnoreCase) ||
                             pokemon.Name.Contains("zarude", StringComparison.OrdinalIgnoreCase) ||
                             pokemon.Name.Contains("pecharunt", StringComparison.OrdinalIgnoreCase);

        return FilterState.IncludeMythical || !isMythicalName;
    }

    private static int GetGeneration(int id)
    {
        return id switch
        {
            <= 151 => 1,
            <= 251 => 2,
            <= 386 => 3,
            <= 493 => 4,
            <= 649 => 5,
            <= 721 => 6,
            <= 809 => 7,
            <= 905 => 8,
            _ => 9
        };
    }

    private static readonly string[] KnownTypes =
    [
        "normal", "fire", "water", "electric", "grass", "ice", "fighting", "poison",
        "ground", "flying", "psychic", "bug", "rock", "ghost", "dragon", "dark",
        "steel", "fairy"
    ];
}

<style>
    .pokedex-container {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 0;
        width: 100%;
        height: 100%;
        padding: 1.5rem;
    }

    .filters-sidebar {
        border-right: 1px solid var(--border);
        padding-right: 1.5rem;
        overflow-y: auto;
        max-height: calc(100vh - 100px);
    }

    .filters-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1rem;
    }

    .filters-header h2 {
        margin: 0;
        font-size: 1.1rem;
        font-weight: 700;
    }

    .clear-button {
        padding: 0.4rem 0.8rem;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: var(--surface);
        color: var(--text);
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s ease, border-color 0.2s ease;
    }

    .clear-button:hover {
        background: var(--surface-alt);
        border-color: var(--accent);
    }

    .search-label {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin-bottom: 1.25rem;
    }

    .search-label span {
        font-weight: 600;
        font-size: 0.9rem;
    }

    .search-input {
        padding: 0.75rem;
        border: 1px solid var(--border);
        border-radius: 8px;
        background: var(--surface);
        color: var(--text);
        font-size: 0.95rem;
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }

    .search-input:focus {
        outline: none;
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
    }

    .filter-group {
        margin-bottom: 1.25rem;
    }

    .filter-title {
        font-weight: 700;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.3px;
        margin-bottom: 0.75rem;
        color: var(--text);
    }

    .filter-check {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        margin-bottom: 0.5rem;
        cursor: pointer;
        user-select: none;
    }

    .filter-check input[type="checkbox"] {
        width: 18px;
        height: 18px;
        cursor: pointer;
        accent-color: var(--accent);
    }

    .filter-check span {
        font-size: 0.95rem;
        text-transform: capitalize;
    }

    .type-pill {
        padding: 0.4rem 0.75rem;
        border-radius: 999px;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .pokedex-content {
        min-width: 0;
        padding-left: 1rem;
    }

    .pokedex-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .pokedex-header h1 {
        margin: 0 0 0.5rem 0;
        font-size: 2rem;
    }

    .pokedex-header p {
        margin: 0;
        color: var(--muted);
    }

    .result-count {
        padding: 0.6rem 1rem;
        border-radius: 999px;
        background: linear-gradient(135deg, #eef2ff 0%, #e0e7ff 100%);
        color: #3730a3;
        font-weight: 700;
        font-size: 0.95rem;
