@using System.Globalization
@using PokeApiNet

<div class="evolution-container">
    <div class="evolution-card">
        <div class="evolution-header">
            <div class="evolution-sprite">
                @if (!string.IsNullOrWhiteSpace(SpriteUrl))
                {
                    <img src="@SpriteUrl" alt="@Node.Species.Name sprite" loading="lazy" />
                }
                else
                {
                    <div class="sprite-placeholder">No sprite</div>
                }
            </div>

            <div class="evolution-info">
                <div class="evolution-name">@Node.Species.Name</div>
                @if (Node.IsBaby)
                {
                    <div class="evolution-stage">Baby Form</div>
                }
            </div>
        </div>

        @if (Node.EvolutionDetails.Count > 0)
        {
            <div class="evolution-conditions">
                @foreach (var detail in Node.EvolutionDetails)
                {
                    <div class="condition">
                        <span class="condition-icon">→</span>
                        <span class="condition-text">@FormatDetail(detail)</span>
                    </div>
                }
            </div>
        }
    </div>

    @if (Node.EvolvesTo.Count > 0)
    {
        <div class="evolution-arrow">↓</div>
        <div class="evolution-branches">
            @foreach (var child in Node.EvolvesTo)
            {
                <PokemonEvolutionNode Node="child" SpriteMap="SpriteMap" />
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public ChainLink Node { get; set; } = default!;

    [Parameter, EditorRequired]
    public IReadOnlyDictionary<string, string?> SpriteMap { get; set; } = new Dictionary<string, string?>();

    private string? SpriteUrl => SpriteMap.TryGetValue(Node.Species.Name, out var sprite) ? sprite : null;

    private static string FormatDetail(EvolutionDetail detail)
    {
        var parts = new List<string>();

        if (!string.IsNullOrWhiteSpace(detail.Trigger?.Name))
            parts.Add(FormatToken(detail.Trigger.Name));

        if (detail.MinLevel is not null)
            parts.Add($"Lv. {detail.MinLevel}");

        if (!string.IsNullOrWhiteSpace(detail.Item?.Name))
            parts.Add($"Item: {FormatToken(detail.Item.Name)}");

        if (!string.IsNullOrWhiteSpace(detail.HeldItem?.Name))
            parts.Add($"Held: {FormatToken(detail.HeldItem.Name)}");

        if (!string.IsNullOrWhiteSpace(detail.KnownMove?.Name))
            parts.Add($"Move: {FormatToken(detail.KnownMove.Name)}");

        if (!string.IsNullOrWhiteSpace(detail.KnownMoveType?.Name))
            parts.Add($"Type: {FormatToken(detail.KnownMoveType.Name)}");

        if (!string.IsNullOrWhiteSpace(detail.TradeSpecies?.Name))
            parts.Add($"Trade for {FormatToken(detail.TradeSpecies.Name)}");

        if (!string.IsNullOrWhiteSpace(detail.PartySpecies?.Name))
            parts.Add($"Party: {FormatToken(detail.PartySpecies.Name)}");

        if (!string.IsNullOrWhiteSpace(detail.PartyType?.Name))
            parts.Add($"Party type: {FormatToken(detail.PartyType.Name)}");

        if (detail.MinHappiness is not null)
            parts.Add($"Happiness {detail.MinHappiness}");

        if (detail.MinAffection is not null)
            parts.Add($"Affection {detail.MinAffection}");

        if (detail.MinBeauty is not null)
            parts.Add($"Beauty {detail.MinBeauty}");

        if (!string.IsNullOrWhiteSpace(detail.TimeOfDay))
            parts.Add($"Time: {detail.TimeOfDay}");

        if (detail.NeedsOverworldRain)
            parts.Add("Rain");

        if (detail.TurnUpsideDown)
            parts.Add("Turn upside down");

        if (detail.Gender is not null)
            parts.Add(detail.Gender == 1 ? "Female" : detail.Gender == 2 ? "Male" : $"Gender {detail.Gender}");

        if (parts.Count == 0)
            return "Unknown requirement";

        return string.Join(" • ", parts);
    }

    private static string FormatToken(string value)
    {
        return CultureInfo.CurrentCulture.TextInfo.ToTitleCase(value.Replace('-', ' '));
    }
}

<style>
    .evolution-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
    }

    .evolution-card {
        border: 1px solid var(--border);
        border-radius: 1.25rem;
        background: var(--surface);
        padding: 1.5rem;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        width: 100%;
        max-width: 280px;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .evolution-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
    }

    .evolution-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
    }

    .evolution-sprite {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 160px;
        height: 160px;
        background: linear-gradient(135deg, var(--surface), var(--surface-alt));
        border-radius: 1rem;
        border: 2px solid rgba(148, 163, 184, 0.2);
    }

    .evolution-sprite img {
        max-width: 100%;
        max-height: 140px;
        object-fit: contain;
    }

    .sprite-placeholder {
        color: var(--muted);
        font-size: 0.875rem;
    }

    .evolution-info {
        text-align: center;
        width: 100%;
    }

    .evolution-name {
        text-transform: capitalize;
        font-weight: 800;
        font-size: 1.125rem;
        letter-spacing: 0.3px;
    }

    .evolution-stage {
        display: inline-block;
        margin-top: 0.5rem;
        padding: 0.25rem 0.75rem;
        border-radius: 999px;
        background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
        color: white;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .evolution-conditions {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        margin-top: 1rem;
        padding-top: 1rem;
        border-top: 2px solid rgba(148, 163, 184, 0.15);
    }

    .condition {
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
        font-size: 0.875rem;
        color: var(--text-secondary);
    }

    .condition-icon {
        flex-shrink: 0;
        color: #6366f1;
        font-weight: bold;
    }

    .condition-text {
        flex: 1;
        line-height: 1.4;
    }

    .evolution-arrow {
        font-size: 1.5rem;
        color: #6366f1;
        font-weight: bold;
        opacity: 0.6;
    }

    .evolution-branches {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.5rem;
        width: 100%;
    }

    @@media (max-width: 640px) {
        .evolution-branches {
            grid-template-columns: 1fr;
        }

        .evolution-card {
            max-width: 100%;
        }
    }
</style>
